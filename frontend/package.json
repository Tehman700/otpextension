{
  "name": "otp-extension",
  "description": "Automatically detects and fills one-time verification codes from Gmail into web forms.",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@types/chrome": "^0.2.2",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0",
    "wxt": "^0.20.27"
  },
  "dependencies": {
    "@fontsource/eb-garamond": "^5.2.7",
    "@fontsource/inter": "^5.2.8"
  }
}
